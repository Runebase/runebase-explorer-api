# Server
PORT=7001
NODE_ENV=development

# MySQL Database
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=runebaseinfo
DB_USER=runebaseinfo
DB_PASS=Runebaseinfo1!

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Runebase
RUNEBASE_CHAIN=mainnet
EXPLORER_DAEMON_PATH=../runebase-explorer-daemon
EXPLORER_DAEMON_WS_PORT=3001

# Runebase RPC
RPC_PROTOCOL=http
RPC_HOST=localhost
RPC_PORT=9948
RPC_USER=runebaseinfo
RPC_PASS=runebaseinfo

# CoinMarketCap (optional)
CMC_API_KEY=

# Rate Limiting
RATE_LIMIT_DURATION=600000
RATE_LIMIT_MAX=600

# Logging
LOG_LEVEL=info
