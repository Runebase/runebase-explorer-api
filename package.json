{
  "name": "runebaseinfo-api",
  "version": "1.0.0",
  "private": true,
  "description": "Runebase blockchain explorer API",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "NODE_ENV=development npx nodemon --exec 'npx babel-node' --max-old-space-size=4096 src/index.mjs",
    "start": "NODE_ENV=production node --max-old-space-size=4096 dist/index.mjs",
    "build": "rm -rf dist && babel src --out-dir dist --copy-files --keep-file-extension",
    "lint": "eslint ."
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "mysql2": "^3.11.5",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "redis": "^5.11.0",
    "sequelize": "^6.37.8",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/node": "^7.29.0",
    "@babel/plugin-syntax-import-assertions": "^7.28.6",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/runtime": "^7.29.2",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14"
  }
}
